generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = "libsql://botdefaimastra-joenationj.aws-ap-northeast-1.turso.io"
}

model Wallet {
  id         String   @id @default(cuid())
  telegramId String   @unique
  username   String?  @unique
  address    String
  privateKey String
  createdAt  DateTime @default(now())
}
