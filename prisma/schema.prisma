generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  
}

model Wallet {
  id         String   @id @default(cuid())
  telegramId String   @unique
  username   String?  @unique
  address    String
  privateKey String
  createdAt  DateTime @default(now())
}
